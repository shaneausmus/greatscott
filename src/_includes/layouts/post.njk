---
layout: layouts/base.njk
---
<article>
  <header class="post-header">
    {% if category %}<p class="post-tag">{{ category }}</p>{% endif %}
    <h1>{{ title }}</h1>
    <p class="post-meta">{{ date | readableDate }}</p>
  </header>
  <div class="post-body">
    {{ content | safe }}
  </div>
  <div class="post-nav">
    <a href="{{ '/blog/' | url }}">← All posts</a>
  </div>
</article>
