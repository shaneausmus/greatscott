<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="dark">
  <title>{% if title and title != "Home" %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:ital,wght@0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  {% if math %}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  {% endif %}
</head>
<body>
  <div class="site-wrapper">

    <aside class="sidebar">
      <div class="sidebar-top">
        <a href="{{ '/' | url }}" class="brand">
          <span class="brand-first">Shane</span>
          <span class="brand-last">Ausmus</span>
        </a>
      </div>

      <nav class="sidebar-nav">
        <ul>
          <li><a href="{{ '/about/' | url }}"{% if page.url == '/about/' %} class="active"{% endif %}><span class="nav-dash"></span>about</a></li>
          <li><a href="{{ '/resume/' | url }}"{% if page.url == '/resume/' %} class="active"{% endif %}><span class="nav-dash"></span>resume</a></li>
          <li><a href="{{ '/projects/' | url }}"{% if page.url == '/projects/' %} class="active"{% endif %}><span class="nav-dash"></span>projects</a></li>
          <li><a href="{{ '/blog/' | url }}"{% if '/blog' in page.url %} class="active"{% endif %}><span class="nav-dash"></span>blog</a></li>
        </ul>
      </nav>

    </aside>

    <div class="site-content">
      <main>
        {{ content | safe }}
      </main>

      <div class="ticker" aria-hidden="true">
        <div class="ticker-track">
          <span class="ticker-item">Data Strategy</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Software Engineering</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Vanderbilt Economics &amp; CS</span><span class="ticker-dot">·</span>
          <span class="ticker-item">McKinsey &amp; Company</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Verkada</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Project Euler Top 2%</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Combinatorics</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Systems Programming</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Language Interpreters</span><span class="ticker-dot">·</span>
          <span class="ticker-item">GTM Engineering</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Data Infrastructure</span><span class="ticker-dot">·</span>
          <!-- duplicate for seamless loop -->
          <span class="ticker-item">Data Strategy</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Software Engineering</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Vanderbilt Economics &amp; CS</span><span class="ticker-dot">·</span>
          <span class="ticker-item">McKinsey &amp; Company</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Verkada</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Project Euler Top 2%</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Combinatorics</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Systems Programming</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Language Interpreters</span><span class="ticker-dot">·</span>
          <span class="ticker-item">GTM Engineering</span><span class="ticker-dot">·</span>
          <span class="ticker-item">Data Infrastructure</span><span class="ticker-dot">·</span>
        </div>
      </div>

      <footer>
        <div class="inner">
          <span>© {{ site.year }} Shane Ausmus. All rights reserved.</span>
          <span>
            <a href="https://github.com/shaneausmus" target="_blank" rel="noopener">GitHub</a>
            <span class="sep">·</span>
            <a href="https://www.linkedin.com/in/shane-ausmus/" target="_blank" rel="noopener">LinkedIn</a>
          </span>
        </div>
      </footer>
    </div>

  </div>

  <script>
    document.addEventListener('mousemove', function(e) {
      document.body.style.setProperty('--mouse-x', (e.clientX / window.innerWidth * 100).toFixed(1) + '%');
      document.body.style.setProperty('--mouse-y', (e.clientY / window.innerHeight * 100).toFixed(1) + '%');
    });
  </script>

  {% if math %}
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"
    onload="renderMathInElement(document.body, {
      delimiters: [
        {left: '$$', right: '$$', display: true},
        {left: '$', right: '$', display: false}
      ]
    });"></script>
  {% endif %}
</body>
</html>
